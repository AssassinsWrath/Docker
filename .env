SERVER_PORT=19132
SERVER_PORT_V6=19133
GAMEMODE=survival
DIFFICULTY=easy
ALLOW_CHEATS=false
MAX_PLAYERS=5
ONLINE_MODE=true
VIEW_DISTANCE=32
TICK_DISTANCE=4
